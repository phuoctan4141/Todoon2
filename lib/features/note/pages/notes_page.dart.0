import 'package:flutter/material.dart';
import 'package:todoon/core/extensions/tag_color_extension.dart';
import 'package:todoon/features/note/models/note_model.dart';
import 'package:todoon/features/note/widgets/note_card.dart';
import 'package:todoon/features/tag/models/tag_model.dart';

class NotesPage extends StatefulWidget {
  const NotesPage({super.key});

  @override
  State<NotesPage> createState() => _NotesPageState();
}

class _NotesPageState extends State<NotesPage> {
  late final List<NoteViewData> mockNoteViewList;

  @override
  void initState() {
    super.initState();
    mockNoteViewList = _buildMockNotes();
  }

  void _sortNotes() {
    mockNoteViewList.sort((a, b) => a.note.position.compareTo(b.note.position));
  }

  List<NoteViewData> _buildMockNotes() {
    final now = DateTime.now();

    // ===== TAGS =====
    final tagWork = TagModel(
      uid: 'tag_work',
      name: 'work',
      color: TagColorEnum.orange,
      createdAt: now,
    );

    final tagHome = TagModel(
      uid: 'tag_home',
      name: 'home',
      color: TagColorEnum.blue,
      createdAt: now,
    );

    final tagIdea = TagModel(
      uid: 'tag_idea',
      name: 'idea',
      color: TagColorEnum.purple,
      createdAt: now,
    );

    // ===== NOTES =====
    final note1 = NoteModel(
      uid: 'note_1',
      planId: 'plan_today',
      content: 'Hoàn thành UI note + tag hôm nay',
      position: 0,
      createdAt: now.subtract(const Duration(hours: 2)),
    );

    final note2 = NoteModel(
      uid: 'note_2',
      planId: 'plan_today',
      position: 1,
      content: 'Refactor TagHorizontalList cho sạch hơn',
      createdAt: now.subtract(const Duration(hours: 5)),
    );

    final note3 = NoteModel(
      uid: 'note_3',
      planId: 'plan_week',
      position: 2,
      content: 'Nghiên cứu UX long press để edit tag',
      createdAt: now.subtract(const Duration(days: 1)),
    );

    // ===== VIEW DATA =====
    return [
      NoteViewData(note: note1, tags: [tagWork, tagIdea]),
      NoteViewData(note: note2, tags: [tagWork]),
      NoteViewData(note: note3, tags: [tagHome, tagIdea]),
    ];
  }

  @override
  Widget build(BuildContext context) {
    _sortNotes();

    return Scaffold(
      appBar: AppBar(title: const Text('Notes'), centerTitle: false),
      body: SafeArea(
        child: ReorderableListView.builder(
          itemCount: mockNoteViewList.length,
          itemBuilder: (context, index) {
            final item = mockNoteViewList[index];
            // Key phải là duy nhất, lấy từ note.uid
            return NoteCard(
              key: ValueKey(item.note.uid),
              note: item.note,
              tags: item.tags,
            );
          },
          onReorder: (int oldIndex, int newIndex) {
            setState(() {
              // Logic điều chỉnh index của Flutter
              if (oldIndex < newIndex) {
                newIndex -= 1;
              }

              // 1. Di chuyển phần tử trong list
              final NoteViewData movedItem = mockNoteViewList.removeAt(
                oldIndex,
              );
              mockNoteViewList.insert(newIndex, movedItem);

              // 2. Cập nhật lại giá trị position trong NoteModel
              // Lưu ý: Vì NoteModel có thể là immutable (final fields),
              // bạn nên dùng copyWith nếu cần. Ở đây mình minh họa cập nhật trực tiếp:
              for (int i = 0; i < mockNoteViewList.length; i++) {
                // Cập nhật giá trị position dựa trên index mới
                mockNoteViewList[i].note = mockNoteViewList[i].note.copyWith(
                  position: i,
                );
              }

              // 3. Log để kiểm tra
              print(
                "Đã đổi vị trí ${movedItem.note.content} sang index $newIndex",
              );
            });

            // Sau bước này, bạn có thể gọi API để lưu lại List<NoteViewData> này
          },
        ),
      ),
    );
  }
}

class NoteViewData {
  NoteModel note;
  List<TagModel> tags;

  NoteViewData({required this.note, required this.tags});
}
